NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Если в проекте Supabase используются Legacy API Keys, можно указать anon key вместо publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_FETCH_TIMEOUT_MS=5000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Локальный dev-вход кнопками ролей. В production должен быть выключен.
DESHAR_ENABLE_DEV_AUTH=0
