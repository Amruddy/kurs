NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Если в проекте Supabase используются Legacy API Keys, можно указать anon key вместо publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_FETCH_TIMEOUT_MS=5000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Локальный dev-вход кнопками ролей. В production должен быть выключен.
DESHAR_ENABLE_DEV_AUTH=0

# Локальный auth smoke. Скрипт обновляет seed-аккаунты Supabase Auth
# временным smoke-паролем и не предназначен для production-проекта.
SMOKE_BASE_URL=http://127.0.0.1:3000
DESHAR_AUTH_SMOKE_PASSWORD=
DESHAR_AUTH_SMOKE_DISABLED_EMAIL=disabled-smoke@example.test
