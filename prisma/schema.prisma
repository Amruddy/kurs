generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationType {
  school
  learning_center
  private_teacher
  other
}

enum OrganizationStatus {
  active
  archived
}

enum UserStatus {
  active
  paused
  archived
}

enum OrganizationMemberStatus {
  active
  paused
  archived
}

enum Role {
  student
  teacher
  admin
  director
}

enum Permission {
  payments_write
  courses_write
  groups_write
  students_write
  materials_write
  journal_write_any
  admin_access
}

enum CourseType {
  tajweed
}

enum CourseFormat {
  group
  individual
  both
}

enum LessonMarkScale {
  five_point
  ten_point
}

enum CourseStatus {
  active
  archived
}

enum StudentStatus {
  active
  paused
  archived
}

enum GroupStatus {
  recruiting
  active
  paused
  completed
  archived
}

enum GroupStudentStatus {
  active
  paused
  removed
  completed
}

enum ScheduleTargetType {
  group
  individual_enrollment
}

enum ScheduleRuleStatus {
  active
  archived
}

enum LessonStatus {
  scheduled
  in_progress
  completed
  cancelled
  moved
}

enum AttendanceStatus {
  not_checked
  confirmed
}

enum AttendanceMark {
  present
  absent
  excused
}

model Organization {
  id        String             @id @default(cuid())
  name      String
  type      OrganizationType
  status    OrganizationStatus @default(active)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  members        OrganizationMember[]
  courses        Course[]
  students       Student[]
  groups         Group[]
  scheduleRules  ScheduleRule[]
  lessons        Lesson[]
  journalEntries JournalEntry[]

  @@map("organizations")
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  phone     String?
  status    UserStatus @default(active)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  memberships    OrganizationMember[]
  createdCourses Course[]             @relation("CourseCreatedBy")
  studentCards   Student[]
  teachingGroups Group[]              @relation("GroupTeacher")
  lessons        Lesson[]             @relation("LessonTeacher")

  @@map("users")
}

model OrganizationMember {
  id             String                   @id @default(cuid())
  organizationId String                   @map("organization_id")
  userId         String                   @map("user_id")
  roles          Role[]                   @default([])
  permissions    Permission[]             @default([])
  status         OrganizationMemberStatus @default(active)
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Course {
  id              String           @id @default(cuid())
  organizationId  String           @map("organization_id")
  name            String
  description     String?
  type            CourseType       @default(tajweed)
  format          CourseFormat     @default(group)
  lessonMarkScale LessonMarkScale? @map("lesson_mark_scale")
  status          CourseStatus     @default(active)
  createdById     String           @map("created_by")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  archivedAt      DateTime?        @map("archived_at")

  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  createdBy        User                    @relation("CourseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  progressSettings CourseProgressSettings?
  groups           Group[]
  lessons          Lesson[]

  @@index([organizationId])
  @@index([createdById])
  @@map("courses")
}

model CourseProgressSettings {
  id                String   @id @default(cuid())
  courseId          String   @unique @map("course_id")
  name              String
  isProgressEnabled Boolean  @default(true) @map("is_progress_enabled")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Restrict)

  @@map("course_progress_settings")
}

model Student {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  userId         String?       @map("user_id")
  name           String
  phone          String?
  email          String?
  status         StudentStatus @default(active)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  archivedAt     DateTime?     @map("archived_at")

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user           User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  contacts       StudentContact[]
  groupLinks     GroupStudent[]
  journalEntries JournalEntry[]

  @@index([organizationId])
  @@index([userId])
  @@map("students")
}

model StudentContact {
  id        String   @id @default(cuid())
  studentId String   @map("student_id")
  name      String
  relation  String?
  phone     String?
  email     String?
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@map("student_contacts")
}

model Group {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  courseId       String      @map("course_id")
  teacherId      String?     @map("teacher_id")
  name           String
  status         GroupStatus @default(recruiting)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  archivedAt     DateTime?   @map("archived_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  course       Course         @relation(fields: [courseId], references: [id], onDelete: Restrict)
  teacher      User?          @relation("GroupTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  students     GroupStudent[]
  lessons      Lesson[]

  @@index([organizationId])
  @@index([courseId])
  @@index([teacherId])
  @@map("groups")
}

model ScheduleRule {
  id             String             @id @default(cuid())
  organizationId String             @map("organization_id")
  targetType     ScheduleTargetType @default(group) @map("target_type")
  targetId       String             @map("target_id")
  weekday        Int
  startTime      String             @map("start_time")
  endTime        String?            @map("end_time")
  timezone       String             @default("Europe/Moscow")
  startsOn       DateTime           @map("starts_on") @db.Date
  endsOn         DateTime?          @map("ends_on") @db.Date
  status         ScheduleRuleStatus @default(active)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  lessons      Lesson[]

  @@index([organizationId])
  @@index([targetType, targetId])
  @@map("schedule_rules")
}

model Lesson {
  id               String           @id @default(cuid())
  organizationId   String           @map("organization_id")
  courseId         String           @map("course_id")
  groupId          String?          @map("group_id")
  teacherId        String           @map("teacher_id")
  scheduleRuleId   String?          @map("schedule_rule_id")
  scheduledAt      DateTime         @map("scheduled_at")
  startsAt         DateTime         @map("starts_at")
  endsAt           DateTime?        @map("ends_at")
  topic            String?
  summary          String?
  lessonStatus     LessonStatus     @default(scheduled) @map("lesson_status")
  attendanceStatus AttendanceStatus @default(not_checked) @map("attendance_status")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  course         Course         @relation(fields: [courseId], references: [id], onDelete: Restrict)
  group          Group?         @relation(fields: [groupId], references: [id], onDelete: Restrict)
  teacher        User           @relation("LessonTeacher", fields: [teacherId], references: [id], onDelete: Restrict)
  scheduleRule   ScheduleRule?  @relation(fields: [scheduleRuleId], references: [id], onDelete: Restrict)
  journalEntries JournalEntry[]

  @@unique([organizationId, scheduleRuleId, startsAt])
  @@index([organizationId])
  @@index([courseId])
  @@index([groupId])
  @@index([teacherId])
  @@index([startsAt])
  @@map("lessons")
}

model JournalEntry {
  id             String          @id @default(cuid())
  organizationId String          @map("organization_id")
  lessonId       String          @map("lesson_id")
  studentId      String          @map("student_id")
  mark           AttendanceMark?
  score          Int?
  comment        String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  lesson       Lesson       @relation(fields: [lessonId], references: [id], onDelete: Restrict)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@unique([lessonId, studentId])
  @@index([organizationId])
  @@index([studentId])
  @@map("journal_entries")
}

model GroupStudent {
  id        String             @id @default(cuid())
  groupId   String             @map("group_id")
  studentId String             @map("student_id")
  status    GroupStudentStatus @default(active)
  joinedAt  DateTime           @default(now()) @map("joined_at")
  leftAt    DateTime?          @map("left_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Restrict)
  student Student @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@unique([groupId, studentId])
  @@index([studentId])
  @@map("group_students")
}
